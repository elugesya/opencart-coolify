# OpenCart 3.x Coolify Environment Configuration
# Copy this to .env and update values for your Coolify deployment

# App Settings
APP_URL=https://your-domain.com
APP_PORT=8080

# Database Settings
DB_ROOT_PASSWORD=your_root_password_here
DB_DATABASE=opencart
DB_USERNAME=opencart
DB_PASSWORD=your_secure_password_here
DB_PREFIX=oc_
